# Server Configuration
PORT=3000
NODE_ENV=development

# LLM Provider — 選擇 anthropic 或 gemini (預設 anthropic)
LLM_PROVIDER=anthropic

# Anthropic (擇一填入即可)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Gemini (擇一填入即可)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Tavily Search API — real attraction/hotel data via MCP (free, no credit card)
# Get key at: https://app.tavily.com
# Without this key, agents fall back to LLM knowledge only (still works)
TAVILY_API_KEY=your_tavily_api_key_here

# Agent Mode (api = direct LLM, a2a = real sub-agent process)
ATTRACTIONS_MODE=api
ACCOMMODATION_MODE=api

# Sub-agent URLs (only needed when MODE=a2a)
ATTRACTIONS_AGENT_URL=http://localhost:3001
ACCOMMODATION_AGENT_URL=http://localhost:3002

# Coordinator Agent Configuration
COORDINATOR_AGENT_ID=travel_coordinator_agent
COORDINATOR_AGENT_NAME=Travel Coordinator Agent
COORDINATOR_AGENT_DESCRIPTION=智能旅遊規劃協調服務

# Task Configuration
MAX_COORDINATION_STEPS=10
TASK_TIMEOUT_MS=300000

# Logging
LOG_LEVEL=info

# Rate Limiting (demo deployment)
DAILY_PLAN_LIMIT=3

# Progressive Map — show map as each agent completes (default: true)
ENABLE_PROGRESSIVE_MAP=true
